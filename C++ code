#include <iostream>
#include <fstream>
using namespace std;

class Product {
public:
    int id;
    string name;
    float price;
};

class CartItem {
public:
    int id;
    string name;
    int qty;
    float totalPrice;
};

// 🛒 Products List
Product products[6] = {
    {1, "Shoes", 2000},
    {2, "Watch", 1500},
    {3, "Bag", 1000},
    {4, "T-Shirt", 800},
    {5, "Headphones", 2500},
    {6, "Sunglasses", 1200}
};

CartItem cart[20];
int cartSize = 0;

// 📦 Show Products
void showProducts() {
    cout << "\n🛒 Available Products:\n";
    for (int i = 0; i < 6; i++) {
        cout << products[i].id << ". "
             << products[i].name << " - ₹"
             << products[i].price << endl;
    }
}

// ➕ Add to Cart
void addToCart() {
    int id, qty;
    cout << "Enter Product ID: ";
    cin >> id;

    cout << "Enter Quantity: ";
    cin >> qty;

    for (int i = 0; i < 6; i++) {
        if (products[i].id == id) {
            cart[cartSize].id = id;
            cart[cartSize].name = products[i].name;
            cart[cartSize].qty = qty;
            cart[cartSize].totalPrice = qty * products[i].price;
            cartSize++;

            cout << "✅ Added to cart!\n";
            return;
        }
    }

    cout << "❌ Invalid Product!\n";
}

// 🧾 View Cart
float viewCart() {
    float total = 0;

    cout << "\n🧾 Your Cart:\n";

    if (cartSize == 0) {
        cout << "Cart is empty!\n";
        return 0;
    }

    for (int i = 0; i < cartSize; i++) {
        cout << cart[i].id << " "
             << cart[i].name << " x"
             << cart[i].qty << " = ₹"
             << cart[i].totalPrice << endl;

        total += cart[i].totalPrice;
    }

    cout << "Total = ₹" << total << endl;
    return total;
}

// ❌ Remove Item
void removeItem() {
    int id;
    cout << "Enter Product ID to remove: ";
    cin >> id;

    for (int i = 0; i < cartSize; i++) {
        if (cart[i].id == id) {
            for (int j = i; j < cartSize - 1; j++) {
                cart[j] = cart[j + 1];
            }
            cartSize--;
            cout << "❌ Item removed!\n";
            return;
        }
    }

    cout << "Item not found!\n";
}

// 💰 Checkout + Save File
void checkout() {
    float total = viewCart();

    if (total == 0) return;

    if (total > 3000) {
        cout << "🎉 Discount Applied (₹200)\n";
        total -= 200;
    }

    cout << "Final Amount = ₹" << total << endl;

