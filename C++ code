    ofstream file("bill.txt");

    file << "===== Shopping Bill =====\n";
    for (int i = 0; i < cartSize; i++) {
        file << cart[i].name << " x"
             << cart[i].qty << " = ₹"
             << cart[i].totalPrice << endl;
    }

    file << "------------------------\n";
    file << "Final Amount = ₹" << total << endl;

    file.close();

    cout << "💾 Bill saved as bill.txt\n";
    cout << "💙 Thank you for shopping!\n";
    cout << "Visit again 😊\n";
}

// 🧠 Main Menu
int main() {
    int choice;

    while (true) {
        cout << "\n========== MENU ==========\n";
        cout << "1. View Products\n";
        cout << "2. Add to Cart\n";
        cout << "3. View Cart\n";
        cout << "4. Remove Item\n";
        cout << "5. Checkout\n";
        cout << "6. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {
            case 1: showProducts(); break;
            case 2: addToCart(); break;
            case 3: viewCart(); break;
            case 4: removeItem(); break;
            case 5: checkout(); break;
            case 6:
                cout << "Exiting... Thank you for shopping! 💙\n";
                return 0;
            default:
                cout << "❌ Invalid choice!\n";
        }
    }
}
